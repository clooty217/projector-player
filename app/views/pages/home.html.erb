<div data-controller="search tv-detail remote bluetooth"
     data-search-remote-outlet="[data-controller~=remote]"
     data-tv-detail-remote-outlet="[data-controller~=remote]"
     data-tv-detail-search-outlet="[data-controller~=search]"
     data-remote-search-outlet="[data-controller~=search]">

  <!-- ── Browse View ── -->
  <div data-search-target="browse">
    <header class="site-header">
      <h1 class="logo">Projector Player</h1>
      <div class="search-bar">
        <input type="text"
               data-search-target="input"
               data-action="input->search#search"
               placeholder="Search movies & TV shows..."
               autofocus>
        <div class="type-toggle">
          <button data-search-target="typeToggle"
                  data-action="click->search#setType"
                  data-type="movie"
                  class="active">Movies</button>
          <button data-search-target="typeToggle"
                  data-action="click->search#setType"
                  data-type="tv">TV Shows</button>
        </div>
      </div>
      <button data-action="click->bluetooth#open" class="header-icon-btn" title="Bluetooth Speakers">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5"/></svg>
      </button>
    </header>

    <main>
      <h2 data-search-target="heading" class="section-heading">Trending Movies</h2>

      <div data-search-target="grid" class="card-grid"></div>

      <div class="pagination">
        <button data-search-target="prevBtn"
                data-action="click->search#prevPage"
                disabled>&larr; Previous</button>
        <span data-search-target="pageInfo">Page 1 of 1</span>
        <button data-search-target="nextBtn"
                data-action="click->search#nextPage"
                disabled>Next &rarr;</button>
      </div>
    </main>
  </div>

  <!-- ── Remote Control Panel ── -->
  <div data-remote-target="panel" class="remote-panel">
    <div class="remote-inner">
      <p data-remote-target="statusText" class="remote-status">Now Playing</p>
      <h2 data-remote-target="title" class="remote-title">Title</h2>

      <div class="remote-controls">
        <button data-action="click->remote#volumeDown" class="remote-btn" title="Volume Down">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="13" x2="17" y2="13"/></svg>
        </button>

        <button data-action="click->remote#pause" data-remote-target="pauseBtn" class="remote-btn remote-btn--primary" title="Pause">
          <svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </button>

        <button data-action="click->remote#resume" data-remote-target="playBtn" class="remote-btn remote-btn--primary hidden" title="Play">
          <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>

        <button data-action="click->remote#volumeUp" class="remote-btn" title="Volume Up">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        </button>
      </div>

      <span data-remote-target="volumeLevel" class="remote-volume-level"></span>

      <div class="remote-seek">
        <button data-action="click->remote#seekBackward" class="remote-btn" title="Rewind 10s">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          <span class="remote-btn-label">10s</span>
        </button>

        <button data-action="click->remote#restart" class="remote-btn" title="Restart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
        </button>

        <button data-action="click->remote#seekForward" class="remote-btn" title="Forward 10s">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10"/></svg>
          <span class="remote-btn-label">10s</span>
        </button>
      </div>

      <div class="remote-seek">
        <button data-action="click->remote#seekBackward60" class="remote-btn" title="Rewind 1 min">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          <span class="remote-btn-label">1m</span>
        </button>

        <div class="remote-seek-spacer"></div>

        <button data-action="click->remote#seekForward60" class="remote-btn" title="Forward 1 min">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10"/></svg>
          <span class="remote-btn-label">1m</span>
        </button>
      </div>

      <button data-action="click->remote#exit" class="remote-exit">
        Exit &amp; Return to Browse
      </button>
    </div>
  </div>

  <!-- ── Sound & Bluetooth Modal ── -->
  <div data-bluetooth-target="modal"
       data-action="click->bluetooth#closeOnBackdrop"
       class="modal-backdrop">
    <div class="modal">
      <div class="modal-header">
        <h2>Sound &amp; Bluetooth</h2>
        <button data-action="click->bluetooth#close" class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <h3 class="modal-section-heading">Audio Output</h3>
        <div data-bluetooth-target="sinkList" class="bt-list"></div>

        <h3 class="modal-section-heading">Bluetooth Devices</h3>
        <div class="bt-toolbar">
          <button data-action="click->bluetooth#scan"
                  data-bluetooth-target="scanBtn"
                  class="bt-scan-btn">Scan for Devices</button>
          <span data-bluetooth-target="scanStatus" class="bt-scan-status"></span>
        </div>
        <div data-bluetooth-target="list" class="bt-list"></div>
      </div>
    </div>
  </div>

  <!-- ── TV Season/Episode Modal ── -->
  <div data-tv-detail-target="modal"
       data-action="click->tv-detail#closeOnBackdrop"
       class="modal-backdrop">
    <div class="modal">
      <div class="modal-header">
        <h2 data-tv-detail-target="title">Show Title</h2>
        <button data-action="click->tv-detail#close" class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <div class="season-picker">
          <label for="season-select">Season</label>
          <select id="season-select"
                  data-tv-detail-target="seasonSelect"
                  data-action="change->tv-detail#loadSeason">
          </select>
        </div>
        <div data-tv-detail-target="episodeList" class="episode-list"></div>
      </div>
    </div>
  </div>
</div>
